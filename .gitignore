# Android 测试分发平台 - Git 忽略文件

# ====================
# 操作系统生成文件
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ====================
# APK 文件（保留文件名，忽略内容）
# ====================
# APK 文件太大，建议通过 LFS 或外部存储管理
# 如果需要 Git LFS，请取消下面的注释
*.apk
# *.apk filter=lfs diff=lfs merge=lfs -text

# ====================
# 敏感信息
# ====================
*.pem
*.key
*.secret
.env
*.env.local
*.env.*.local

# ====================
# 编辑器和 IDE
# ====================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ====================
# 临时文件
# ====================
*.tmp
*.temp
*.log
*.cache

# ====================
# Node.js (如果将来使用)
# ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================
# 发布临时目录
# ====================
to-publish/*.apk
# 但保留 README
!to-publish/README.md

# ====================
# Docker 相关
# ====================
# 忽略本地 docker 卷数据（如果有的话）
# docker-volume-data/

# ====================
# 备份文件
# ====================
*.bak
*.backup
*~

# ====================
# 压缩文件
# ====================
*.zip
*.tar
*.tar.gz
*.rar

# ====================
# 文档草稿
# ====================
*.draft.md
草稿*.md

# ====================
# 测试文件
# ====================
test-*.html
test-*.sh
debug-*.html
